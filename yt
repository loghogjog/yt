#!/usr/bin/env bash

# -------------------------
# FILES
# -------------------------
YT_FOLDER="/tmp/.yt"
CACHE_DIR="$YT_FOLDER/.yt-cache"
THUMB_DIR="$YT_FOLDER/.yt-thumbs"
LAST_QUERY_FILE="$YT_FOLDER/.yt-last"
OFFSET_FILE="$YT_FOLDER/.yt-offset"
HISTORY_FILE="$YT_FOLDER/.yt-history"
QUEUE_FILE="$YT_FOLDER/.yt-queue"

MAX_HISTORY=100
RESULTS_PER_PAGE=20

MPV="/usr/bin/mpv --no-terminal --force-window=yes --ytdl=yes"
YT_DLP="$HOME/.local/bin/yt-dlp --no-warnings --quiet --js-runtimes node --cookies-from-browser firefox"
JQ="/usr/bin/jq"

mkdir -p "$YT_FOLDER" "$CACHE_DIR" "$THUMB_DIR"

# -------------------------
# CLEANUP
# -------------------------
find "$THUMB_DIR" -type f -mtime +2 -delete 2>/dev/null

# -------------------------
# SPINNER
# -------------------------
spinner() {
    local pid=$1
    local spin='|/-\'
    while kill -0 $pid 2>/dev/null; do
        printf "\r Loading... [%c]" "$spin"
        spin=${spin#?}${spin%???}
        sleep 0.1
    done
    printf "\r\033[K"
}

# -------------------------
# THUMBNAILS
# -------------------------
preload_thumbs() {
    while read -r line; do
        id=$(echo "$line" | $JQ -r .id)
        thumb=$(echo "$line" | $JQ -r .thumb)
        file="$THUMB_DIR/$id.jpg"

        [ ! -f "$file" ] && curl -s "$thumb" -o "$file" &
    done
}

# -------------------------
# FORMAT
# -------------------------
format_for_fzf() {
    $JQ -r '"\(.title)\t\(.id)\t\(.url)"'
}

# -------------------------
# SMART RECOMMEND (REAL FIX)
# -------------------------
smart_recommend() {
    [ ! -f "$HISTORY_FILE" ] && return

    tmp=$(mktemp)

    tail -n 5 "$HISTORY_FILE" | while read -r url; do
        $YT_DLP --flat-playlist --dump-json "$url" 2>/dev/null
    done | $JQ -c 'select(.id != null) | {
        id: .id,
        title: .title,
        url: ("https://www.youtube.com/watch?v=" + .id),
        thumb: .thumbnail
    }' > "$tmp"

    shuf "$tmp" | awk '!seen[$0]++' > "$QUEUE_FILE"
}

# -------------------------
# AUTOPLAY LOOP
# -------------------------
autoplay_loop() {
    while true; do
        [ ! -s "$QUEUE_FILE" ] && smart_recommend

        next=$(head -n 1 "$QUEUE_FILE")
        [ -z "$next" ] && break

        url=$(echo "$next" | $JQ -r '.url')
        title=$(echo "$next" | $JQ -r '.title')

        tail -n +2 "$QUEUE_FILE" > "$QUEUE_FILE.tmp" && mv "$QUEUE_FILE.tmp" "$QUEUE_FILE"

        echo -e "\n▶ $title"
        echo "⏭ Press 's' + ENTER to skip"

        $MPV "$url" &
        pid=$!

        (
            read -r key
            [ "$key" = "s" ] && kill $pid 2>/dev/null
        ) &

        wait $pid 2>/dev/null
        reset

        echo "$url" >> "$HISTORY_FILE"
        tail -n $MAX_HISTORY "$HISTORY_FILE" > "$HISTORY_FILE.tmp" && mv "$HISTORY_FILE.tmp" "$HISTORY_FILE"
    done
}

# -------------------------
# SEARCH
# -------------------------
search_mode() {
    query=$(cat "$LAST_QUERY_FILE" 2>/dev/null)
    read -rp "Search: " input
    query="${input:-$query}"

    echo "$query" > "$LAST_QUERY_FILE"

    tmp=$(mktemp)

    (
        $YT_DLP --dump-json "ytsearch20:$query" |
        $JQ -c '{id:.id,title:.title,url:.webpage_url,thumb:.thumbnail}' > "$tmp"
    ) &

    spinner $!

    preload_thumbs < "$tmp"

    formatted=$(mktemp)
    cat "$tmp" | format_for_fzf > "$formatted"

    run_fzf "$formatted"
}

# -------------------------
# RECOMMENDED
# -------------------------
recommend_mode() {
    tmp=$(mktemp)

    (
        $YT_DLP --playlist-items 1-20 --dump-json "https://www.youtube.com" |
        $JQ -c 'select(.webpage_url!=null) | {id:.id,title:.title,url:.webpage_url,thumb:.thumbnail}' > "$tmp"
    ) &

    spinner $!

    preload_thumbs < "$tmp"

    formatted=$(mktemp)
    cat "$tmp" | format_for_fzf > "$formatted"

    run_fzf "$formatted"
}

# -------------------------
# FZF UI
# -------------------------
run_fzf() {
    input_file="$1"
    echo 0 > "$OFFSET_FILE"

    while true; do
        offset=$(cat "$OFFSET_FILE")
        total=$(wc -l < "$input_file")

        start=$((offset + 1))
        end=$((offset + RESULTS_PER_PAGE))
        [ $end -gt $total ] && end=$total

        header=$(printf "ENTER: Play | CTRL-R: Next | ESC: Back\n\n%s" \
            "$(head -n 3 "$QUEUE_FILE" 2>/dev/null | $JQ -r '.title' 2>/dev/null | sed 's/^/⏭ /')")

        selection=$(sed -n "${start},${end}p" "$input_file" | fzf \
            --height=100% \
            --layout=reverse \
            --border \
            --multi \
            --delimiter='\t' \
            --with-nth=1 \
            --header "$header" \
            --bind 'ctrl-r:abort' \
            --preview '
                title={1}
                id=$(echo {2} | tr -d "[:space:]")
                file="'$THUMB_DIR'/$id.jpg"

                printf "\n %s\n\n" "$title"

                if [ -f "$file" ]; then
                    kitty +kitten icat --transfer-mode=memory \
                        --clear --stdin=no \
                        --place 80x55@0x0 \
                        --align center \
                        "$file" 2>/dev/null
                fi
            '
        )

        code=$?
        [ $code -ne 0 ] && break

        # next page
        if [ -z "$selection" ]; then
            offset=$((offset + RESULTS_PER_PAGE))
            [ $offset -ge $total ] && offset=0
            echo $offset > "$OFFSET_FILE"
            continue
        fi

        urls=$(echo "$selection" | awk -F '\t' '{print $3}')

        for url in $urls; do
            echo "$url" >> "$HISTORY_FILE"
        done
        tail -n $MAX_HISTORY "$HISTORY_FILE" > "$HISTORY_FILE.tmp" && mv "$HISTORY_FILE.tmp" "$HISTORY_FILE"

        $MPV $urls
        reset

        count=$(echo "$urls" | wc -w)

        if [ "$count" -gt 1 ]; then
            for url in $urls; do
                echo "{\"url\":\"$url\",\"title\":\"manual\"}" >> "$QUEUE_FILE"
            done
            autoplay_loop
            return
        fi

        if [ "$count" -eq 1 ]; then
            smart_recommend
            autoplay_loop
            return
        fi
    done
}

# -------------------------
# MENU
# -------------------------
choose_mode() {
    mode=$(printf "Search\nRecommended\nQuit" | fzf)

    case "$mode" in
        "Search") search_mode ;;
        "Recommended") recommend_mode ;;
        *) exit ;;
    esac
}

# -------------------------
# MAIN
# -------------------------
while true; do
    choose_mode
done

